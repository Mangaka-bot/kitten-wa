generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  relationMode = "prisma"
}

enum Presence {
  unavailable
  available
  composing
  recording
  paused
}

enum GroupAdmin {
  admin
  superadmin
}

model Message {
  id                  String        @id @unique
  senderId            String?
  groupId             String?
  type                String?
  timestamp           Int?
  raw                 Json?         // WaMessage

  group               Group?        @relation(fields: [groupId], references: [id])
  sender              User?         @relation("SentMessages", fields: [senderId], references: [id])

  @@index([timestamp])
  @@index([groupId])
  @@index([senderId])
  @@index([type])
}

model User {
  id                  String        @id @unique
  name                String?
  notify              String?
  presence            Presence?     @default(unavailable) 
  
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  ownedGroups         Group[]       @relation("GroupOwner")
  groups              Participant[]
  messages            Message[]     @relation("SentMessages")

  metadata            Json?

  @@index([presence])
}

model Group {
  id                  String        @id @unique
  groupInfo           Json

  owner               User?         @relation("GroupOwner", fields: [ownerId], references: [id])
  ownerId             String?

  participants        Participant[]
  messages            Message[]

  metadata            Json?
}

model Participant {
  userId                  String
  groupId             String
  admin               GroupAdmin?

  user                User?         @relation(fields: [userId], references: [id])
  group               Group?         @relation(fields: [groupId], references: [id])

  @@id([userId, groupId])
}